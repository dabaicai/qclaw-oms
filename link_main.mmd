flowchart TD
    A(["商品详情 / 购物车"]) --> B["创建订单草稿·预占库存"]
    B --> C{"校验<br/>商品/库存/地址/限购/风控"}
    C -- 不通过 --> X1["关单·释放库存"]
    C -- 通过 --> D["确认地址/优惠/发票"]
    D --> E["发起支付"]
    E --> F["支付渠道"]
    F --> G{"支付成功回调?"}
    G -- "失败 / 超时" --> X2["超时关单·释放库存"]
    G -- 成功 --> H(["已支付 PAID"])
    H --> I{"风控二次校验"}
    I -- 拦截 --> X3["人工核查 / 退款"]
    I -- 通过 --> J["按商家拆子单"]
    J --> K["商家接单 ACCEPTED"]
    K --> L["拣货 / 出库"]
    L --> M["发货·生成电子面单"]
    M --> N["物流轨迹回传"]
    N --> O{"买家签收?"}
    O -- "超时自动确认" --> P(["已完成 COMPLETED"])
    O -- "手动确认" --> P
    P --> Q["评价"]
    P --> R["分账结算 T+1 / T+7"]
    K -. "超时未发货" .-> W1["提醒 / 平台介入 / 赔付"]
    N -. "物流停滞 / 退回" .-> W2["异常预警·客服跟进"]
    O -. "拒收 / 退回" .-> S0(["买家申请售后"])
    S0 --> SF["进入售后链路"]
    classDef endNode fill:#e8f5e9,stroke:#43a047,color:#1b5e20;
    classDef warn fill:#fff3e0,stroke:#fb8c00,color:#e65100;
    classDef ex fill:#ffebee,stroke:#e53935,color:#b71c1c;
    class P,H endNode;
    class W1,W2 warn;
    class X1,X2,X3 ex;
